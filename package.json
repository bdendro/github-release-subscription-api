  "type": "commonjs",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "tsx src/main.ts",
    "start:dev": "tsx watch src/main.ts",
    "start:prod": "node dist/main.js",
    "format": "prettier --write .",
    "format:diff": "prettier --list-different . --ignore-unknown",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "migrate:dev": "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy",
    "generate:prisma": "prisma generate",
    "test": "npm run test:unit",
    "test:unit": "cross-env NODE_ENV=test jest --config jest.config.json"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "axios": "^1.15.0",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ms": "^2.1.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@octokit/types": "^16.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.5.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "cross-env": "^10.1.0",
