    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "prettier": "3.8.1",
    "prisma": "^7.7.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
